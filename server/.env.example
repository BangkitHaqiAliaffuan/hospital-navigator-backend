# Server Configuration
PORT=3001
NODE_ENV=production

# CORS Configuration
# IMPORTANT: Add your frontend URL here!
# Multiple origins separated by comma (no spaces)
ALLOWED_ORIGINS=https://hospitalnavigator-lake.vercel.app,https://hospital-navigator-frontend.vercel.app

# For local development:
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# For wildcard Vercel domains (less secure, but convenient):
# ALLOWED_ORIGINS=https://hospitalnavigator-lake.vercel.app,https://*.vercel.app

# API Configuration
API_PREFIX=/api/v1
