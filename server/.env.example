# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
# For local development - multiple origins separated by comma
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:3000,http://127.0.0.1:8080

# For production (Vercel), set in Vercel Environment Variables:
# ALLOWED_ORIGINS=https://hospitalnavigator-lake.vercel.app,https://*.vercel.app
#
# Example with multiple domains:
# ALLOWED_ORIGINS=https://example.com,https://app.example.com,https://*.vercel.app

# API Configuration
API_PREFIX=/api/v1
